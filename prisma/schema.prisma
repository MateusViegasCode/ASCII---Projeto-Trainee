// Prisma Client gera o codigo de acesso ao banco
// e evita que o SQL fique solto no meio do projeto.
generator client {
  provider = "prisma-client-js"
}

// Fonte de dados local usando SQLite.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tabela principal de usuarios.
model User {
  id        Int      @id @default(autoincrement()) // identificador unico
  nome      String   // nome do usuario
  email     String   @unique // email unico
  senha     String   // hash da senha gerado pelo bcrypt
  createdAt DateTime @default(now()) // data de criacao
}
